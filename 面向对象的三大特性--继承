#3.多继承
#3.1子类有多个父类，并且具有所有父类的属性与方法
class Father(object):
    def money(self):
     print('拥有钱')
class Mother(object):
    def apperance(self):
     print('高颜值')
class Son(Father,Mother):
    pass
son = Son()
son.money()
son.apperance()
#不同的父类有同样的方法时，调用就近原则，括号内哪一个离得最近，优先调用哪一个类的方法
#3.3方法的搜索顺序
#python中的内置属性__mro__可以查看方法搜索顺序
class Father(object):
    def money(self):
     print('拥有钱')
class Mother(object):
    def apperance(self):
     print('高颜值')
class Son(Father,Mother):
    pass
son = Son()
son.money()
son.apperance()
print(Son.__mro__)  #注意是两个"_"
#搜索方法时，会按照__mro__的是输出结果，从左往右的顺序查找
#如果当前类找到了方法，就直接不再搜索，若没有找到方法，程序会报错。




     




   
