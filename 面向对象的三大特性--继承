#1.3多重传递
#A/B/C C继承于B，B继承A，C具有A/B的属性与方法
#子类拥有父类的属性与方法
class Father:    
    def eat(self):
        print("eat")
    def sleep(self):
        print("sleep")
class Son(Father):
    pass
son = Son()
son.eat()
class Grandson(Son):  #切记：括号里的只能是类名，因此要大写
    pass
grandson = Grandson()
grandson.sleep()

#问题：为什么在son中没有sleep但在grandson中可以运行？
#解答：因为其实son中有的，但只是没有将其表现出来

#1.4重写
#指在子类中定义与父类相同名称的方法
#1.4.1方法的重写
#含义：如果从父类继承的方法不能满足子类的需求，可以在子类中重写父类的方法，为方法重写
#实现的三种方法：
#1.父类名.方法名（self）
#2.super().方法名()---推荐使用
#3.super(子类名,self).方法名
#在子类中定义与父类相同的方法
class Person:   
    def money(self):
        print("有钱")
class Man(Person):
    def money(self):  #子类自己进行定义了
        print("挣钱")
man = Man()
man.money()    #若子类有，以子类的为主
#1.4.2对子类方法进行扩展，有父的，也有自身的，用super（）.方法名()
#类加小括号是在创建实例化对象
class Person:   
    def money(self):
        print("有钱")
class Man(Person):
    def money(self): 
    super().money()
        print("挣钱")
man = Man()
man.money()  
