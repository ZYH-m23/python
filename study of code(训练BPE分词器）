import collections  
import re
from typing import Dict, List, Tuple

# import是用来调用数据库。collection用来统计频率；re是正则表达式库用于拆分文本；typing用于标注变量类型，
如Dict[int,bytes]即“键是int,值是bytes的字典”

#读取输入文本
def train_bpe_tokenizer(input_path: str, vocab_size: int, special_tokens: List[str]) -> Tuple[  
    Dict[int, bytes], List[Tuple[bytes, bytes]]]:                                     
    with open(input_path, 'r', encoding='utf-8') as f:
        text = f.read()
        
#A.(input_path: str, vocab_size: int, special_tokens: List[str])是函数参数，有不同参数的类型，List[str]表
明是一个字符串组成的列表，实际作用是加入词汇表
#  的特殊标记，如['<<<|endoftext|>','<<<|unk|>']第一个是文本结束标记，第二个是未知字符标记，防止报错
#B.->后面的内容是函数返回值的类型标志，表示函数运行完会返回一个元组，里面有两个元素，一个是键为int,值为bytes的字典，第二个是
#  元素为（bytes, bytes）元组的列表 （对应合并规则），对应合并规则是指按照高频字节对顺序记录的“谁和谁合并成新的token”的清单。
#  举例：比如训练中先合并 (b'a', b'p') 成 b'ap ，再合并 (b'ap', b'p') 成 b'app ，那合并规则就是：
#[(b'a', b'p'), (b'ap', b'p')] ，对应说明书内容：“1. a+p→ap；2. ap+p→app”。
#C.此函数即：1.文本文件在哪（字符串）2.要做多大的词汇表（数字）3.要加哪些特殊标记（字符串列表）
#D. with ... as f ：Python的“上下文管理器”，作用是“自动管理文件的打开/关闭”（不用手动写 f.close() ，避免忘记关闭文件导致的问题
#E. open 是Python内置的“打开文件”函数；
#   -第一个参数 input_path ：要打开的文件路径（就是前面函数参数传进来的那个字符串）；
#   -第二个参数 'r' ：表示“以只读模式打开文件”（只能看文件内容，不能修改）；
#   -第三个参数 encoding='utf-8' ：表示“用UTF-8编码读取文件”（确保中文、特殊符号等能正确读取）
#F. text = f.read() ：调用文件对象 f 的 read() 方法，把文件里的所有内容一次性读出来，存到变量 text 里

#初始化词汇表
    vocab = {}
    merges = []
    token_id = 0
    for token in special_tokens:
        vocab[token_id] = token.encode('utf-8')  #将“当前 token_id ”作为键、“编码后的字节序列”作为值，存入 vocab 字典 
        token_id += 1   #每次处理完一个特殊Token， token_id 自增1，为下一个Token分配新ID
    for byte_val in range(256):
        vocab[token_id] = bytes([byte_val])  #将“当前 token_id ”和“字节序列”存入 vocab 字典
        token_id += 1    
        
#  vocab 是字典，存“TokenID→字节序列”； merges 是列表，存合并规则，将小单元合并为更大的token。
#  先把 special_tokens （比如 <<|endoftext|> ）转成字节（ encode('utf-8') ），分配TokenID并存入 vocab 。
#  再把0-255共256个字节（计算机最基础的字符单元）分配TokenID，加入 vocab
#  每个字节对应一个基础字符 

#拆分文本为单词，统计单词的频率
    words = re.findall(r'\S+|\s+', text)  #将text拆分成非空白单词与空白字符段的列表words
    if not words:
        return vocab, merges
    word_freqs = collections.Counter()  # collections.Counter()-  collections.Counter  是 Python 内置的“计数器”工具，
#                用于统计可迭代对象中元素的出现次数。这里初始化一个空的  Counter ，后续用来统计“字节序列形式的单词”出现的频率。
    for word in words:
        word_bytes = word.encode('utf-8')
        word_freqs[word_bytes] += 1

#   用正则 r'\S+|\s+' 把文本拆成“非空白字符（单词）”和“空白字符（空格/换行）”，存到 words 里
#正则表达式  \S+  能匹配连续的非空白字符（ \S  表示非空白字符， +  表示至少一个）， \s+  能匹配连续的空白字符
#（ \s表示空白字符，+表示至少一个），二者结合的\S+|\s+  可以精准且完整地把文本按“非空白段 + 空白段 + 非空白段 + 
#空白段……”的结构拆分，不会遗漏或错误分割文本的组成部分

#把每个单词拆成基础字节序列
    symbols = {}
    for word_bytes, freq in word_freqs.items():
        symbols[word_bytes] = [bytes([b]) for b in word_bytes]

# 建字典 symbols ，键是“字节形式的单词”，值是“这个单词拆成单个字节的列表”
# 比如单词“apple”转字节是 b'apple' ，拆成 [b'a', b'p', b'p', b'l', b'e'] 
# 把每个单词拆成最基础的“字母/符号单元”，比如“apple”拆成 ["a", "p", "p", "l", "e"] ，方便后面合并

#循环合并高频字节对
    while len(vocab) < vocab_size:
        pair_freqs = collections.Counter()
        for word_bytes, word_symbols in symbols.items():
            for i in range(len(word_symbols) - 1):    #防止越界
                pair = (word_symbols[i], word_symbols[i + 1])
                pair_freqs[pair] += word_freqs[word_bytes]
        if not pair_freqs:
            break
        best_pair = max(pair_freqs, key=pair_freqs.get)
        new_token = best_pair[0] + best_pair[1]
        vocab[token_id] = new_token
        token_id += 1
        merges.append(best_pair)

#  vocab是我们要构建的词汇表，“vocab_size”是我们想要的词汇表总大小（比如想要50000个Token），
   只要当前词汇表里的Token数量还没到目标值，就一直重复后面的操作
# symbols”是一个字典，存着“每个单词的字节序列 → 这个单词拆成的基础符号列表”（比如单词“apple”对应的 word_bytes 是 b'apple' ，
#   word_symbols 是 [b'a', b'p', b'p', b'l', b'e'] ），即把每个单词的“字节序列”和“拆分后的符号列表”都取出来，逐个处理
#  pair = (word_symbols[i], word_symbols[i + 1])把相邻的两个符号打包成一个“字节对”
# merges”是用来存“合并历史”的列表，把这次合并的 best_pair （比如 (b'p', b'p') ）存进去，后面编码文本时，要按照这个顺序合并符号

#用新合并的token更新所有单词的拆分形式
        for word_bytes, word_symbols in symbols.items():
            new_symbols = []    #更新拆分方式
            i = 0   #i 是“当前遍历到的符号位置”的指针（比如 word_symbols 是 [b'a', b'p', b'p'] ， i=0 对应第一个符号 b'a' ）
            while i < len(word_symbols):
                if i < len(word_symbols) - 1 and word_symbols[i] == best_pair[0] and word_symbols[i + 1] == best_pair[
                    1]:
                    new_symbols.append(new_token)
                    i += 2             #因为和下一个已经合并为一个了，所以是+2
                else:
                    new_symbols.append(word_symbols[i])
                    i += 1
            symbols[word_bytes] = new_symbols   #更新当前的符号拆分列表，确保后续循环能基于更新后的拆分方式统计新的字节对
        if len(vocab) >= vocab_size:
            break
    return vocab, merges

#print_vocab_and_merges函数，打印结果
def print_vocab_and_merges(vocab: Dict[int, bytes], merges: List[Tuple[bytes, bytes]]):
    print("词汇表（Token ID -> 字节序列）：")
    for tok_id, byte_seq in sorted(vocab.items()):#  先把 vocab 按Token ID从小到大排序，然后逐个取出
                                                   Token ID（ tok_id ）和对应的字节序列（ byte_seq ）
        try:
            decoded = byte_seq.decode('utf-8', errors='replace')
            if len(decoded) == 1 and ord(decoded) < 32:
                decoded = f"\\x{ord(decoded):02x}"
        except:
            decoded = str(byte_seq)
        print(f"{tok_id}: {decoded}")  # 打印单个的Token的信息
    print("\n合并规则（按顺序）: ")
    for i, pair in enumerate(merges):
        try:
            part1 = pair[0].decode('utf-8', errors='replace')
            if len(part1) == 1 and ord(part1) < 32:
                part1 = f"\\x{ord(part1):02x}"
        except:
            part1 = str(pair[0])
# 1.尝试用 utf-8 把字节解码成字符串；如果解码失败（比如非UTF-8字节），用 replace 填充占位符；
# 2. 若解码后是单个不可见控制字符（ASCII码<32），转成 \xXX 格式（比如换行符 \n 转成 \x0a ）；
# 3. 若解码报错，直接把原始字节转成字符串（比如 b'\x80' ）
        try:
            part2 = pair[1].decode('utf-8', errors='replace')
            if len(part2) == 1 and ord(part2) < 32:
                part2 = f"\\x{ord(part2):02x}"
        except:
            part2 = str(pair[1])
        try:
            merged = (pair[0] + pair[1]).decode('utf-8', errors='replace')
            if len(merged) == 1 and ord(merged) < 32:
                merged = f"\\x{ord(merged):02x}"
        except:
            merged = str(pair[0] + pair[1])
        print(f"{i + 1}. {part1} + {part2} -> {merged}") #按序号. 合并前符号A + 合并前符号B -> 合并后新符号 的格式输出
                          #  其中 i+1 是合并规则的序号（从1开始）， part1/part2 是之前处理好的“合并前两个符号的可读形式”，
                           #                                                      merged 是“合并后新符号的可读形式”。
# A.  vocab ：字典类型，键是Token ID（整数），值是对应的字节序列（bytes）；
# B. merges ：列表类型，每个元素是“合并的字节对”（比如 (b'p', b'p') ）
# C.  ord(decoded) ：获取这个字符对应的ASCII码值（比如字符 'a' 的ASCII码是97，换行符 '\n' 的ASCII码是10）。
#    < 32 ：ASCII码中，0~31对应的是“控制字符”（比如换行、回车、空格、制表符等），这些字符通常是“不可见的”，
#   直接打印会导致格式混乱（比如换行符会真的换行）。
# D.“单个不可见控制字符”的格式化：
# ord(decoded) ：获取该字符的ASCII码值（比如换行符 \n 的ASCII码是10）；
# :02x ：把ASCII码转成两位十六进制数（比如10会转成 0a ）；
# \\x ：最终会显示为 \x （因为Python中 \ 是转义符，需要写两个 \\ 才能输出一个 \ ）。
# 比如：换行符 \n （ASCII码10）会被格式化为 \x0a ，这样打印时就能明确看到这是“ASCII码为10的控制字符”，而不是真的
# 2.  except: decoded = str(byte_seq) 
# 这是处理解码失败的情况： 前面的 try 块尝试用UTF-8解码字节序列，但有些字节序列（比如非UTF-8编码的字节）可能解码失败，此时会触发 except
# 触发后，直接把原始的字节序列（ byte_seq ）转成字符串（比如 b'\x80' ），这样至少能看到字节的原始形式，不会因为解码失败导致程序崩溃。
# E.enumerate(merges) 会同时拿到“合并规则的序号”和“对应的字节对”；
#  内部会对字节对（ part1 、 part2 ）做和上面一样的解码处理，转成可读字符串；
#  按“序号. 合并前的两个符号 + 合并前的两个符号 -> 合并后的新符号”的格式打印
# 通过解码、特殊字符格式化，把BPE的“字节级合并规则”转成人类能直观理解的形式，方便查看BPE是如何从基础字节逐步合并出长Token的

# 主程序（测试代码）
if __name__ == "__main__":
    test_text = "apple banana cat dog elephant hello world this is a test"
    with open('test_data.txt', 'w', encoding='utf-8') as f:
        f.write(test_text)
    vocab, merges = train_bpe_tokenizer('test_data.txt', 50, ['<|endoftext|>', '<|unk|>'])
    print(f"词汇表大小: {len(vocab)}")
    print_vocab_and_merges(vocab, merges)

